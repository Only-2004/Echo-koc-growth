# =============================================================================
# Beacon · KOC 成长伙伴 · 环境变量模板
# -----------------------------------------------------------------------------
# 用法：
#   cp .env.example .env
#   然后在 .env 里填入真实 key（.env 已 gitignore + sandbox 硬隔离）
#
# 红线：
#   - .env 不可提交到 git
#   - 代码中不允许任何 hardcoded key（统一 os.getenv / process.env）
#   - 日志要过滤含 KEY / SECRET / TOKEN 关键词的行
# =============================================================================


# -----------------------------------------------------------------------------
# 1) DeepSeek v4 · 主力 LLM（必填）
# -----------------------------------------------------------------------------
# 申请地址：https://platform.deepseek.com/api_keys
# 单一 API key 同时驱动三档模型：flash / flash-thinking / pro-thinking
# Demo 默认走缓存（USE_CACHED_ANALYSIS=true），密钥额度需求很低；调试或重跑预跑脚本时才会真实消耗

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 三档模型名（与 PRD §7.2 对应；以 DeepSeek 官方实际可用模型 ID 为准，下面是占位）
# - flash：最低延迟 + 快速分类（VALIDATE 等动作分类）
# DeepSeek 实际只暴露两个 model id；thinking 档位通过 extra_body 控制
# - flash：驱动 flash / flash-thinking 两档（thinking 由 client 内部启用）
# - pro：驱动 pro-thinking 档
MODEL_FLASH=deepseek-v4-flash
MODEL_PRO=deepseek-v4-pro

# 各档 max_tokens 下限（thinking 档 reasoning tokens 计入此预算，预算太小会
# 导致推理吃光额度、final answer 为空）。调用方传更大的值仍会生效。
MAX_TOKENS_FLASH=2048
MAX_TOKENS_FLASH_THINKING=8192
MAX_TOKENS_PRO_THINKING=16384


# -----------------------------------------------------------------------------
# 2) 应用运行参数（必填，但可保持默认）
# -----------------------------------------------------------------------------
# Demo 演示时强烈建议 true：所有 ANALYZE / SCORE / STRATEGIZE / SYNTHESIZE 阶段直接读 cache/*.json，避免现场 LLM 输出方差
# 开发与调试时设 false 走真实 LLM
USE_CACHED_ANALYSIS=true

# 全兜底模式：true 时所有 LLM 调用直接走 hardcoded fallback（应急演示用）
USE_FALLBACK_ALL=false

# LLM 重试配置
LLM_MAX_RETRIES=2
LLM_RETRY_MIN_WAIT=1
LLM_RETRY_MAX_WAIT=8

# LLM 超时配置（秒）
LLM_TIMEOUT_FIRST_TOKEN=8
LLM_TIMEOUT_TOTAL=30

# Admin API token（切换 fallback 模式用，留空则不启用 admin 端点）
ADMIN_TOKEN=

LOG_LEVEL=info

# 后端端口（FastAPI 默认 8000；前端 Vite 默认 5173）
PORT=8000

# CORS 允许源（本地开发；生产由实际域名替代）
CORS_ORIGIN=http://localhost:5173

# 公网域名（部署后填入，用于评委访问）
PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# 3) 前端环境变量（Vite 自动加载 VITE_ 前缀；写入 frontend/.env.local 而非根目录）
# -----------------------------------------------------------------------------
# 仅作模板参考，实际请放到 frontend/.env.local（同样 gitignore）
#
# VITE_API_BASE_URL=http://localhost:8000
# VITE_PUBLIC_PERSONA=xiaoA


# =============================================================================
# 以下是 task-master AI 的内置模板（保留以兼容 task-master parse-prd / expand 等
# 需要外部 LLM 的命令；Beacon 主体功能不依赖以下任何 key）
# =============================================================================

# API Keys (Required to enable respective provider in task-master)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # For task-master --research; Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require auth.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export.
