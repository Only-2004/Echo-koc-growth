# =============================================================================
# Beacon · gitignore
# =============================================================================

# 环境变量与密钥（绝对不可提交）
.env
.env.*
!.env.example
*.key
*credentials*
*secrets*

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Vite / Next
node_modules/
dist/
build/
.next/
.cache/

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# 运行时数据 / 缓存（由 agent 产出，不入库）
runtime_data/
cache/
backend/runtime_data/
backend/cache/

# Claude / IDE
.claude/worktrees/
.claude/tasks/
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系统
.DS_Store
Thumbs.db
